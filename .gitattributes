# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for these (cross-platform code/config files)
*.cs           text eol=lf
*.csproj       text eol=lf
*.sln          text eol=crlf
*.props        text eol=lf
*.targets      text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.md           text eol=lf
*.editorconfig text eol=lf
*.gitignore    text eol=lf
*.gitattributes text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.dll   binary
*.exe   binary
*.nupkg binary
*.zip   binary
