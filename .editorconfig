root = true

###############################
# All files
###############################
[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

###############################
# C# files
###############################
[*.cs]
indent_size = 4

# ---------------------------------------------------------------------------
# Naming rules — match GameBackend Coding Standards v1.0 §1.1
# ---------------------------------------------------------------------------

# Symbol groups
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_symbols.private_static_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_static_fields.required_modifiers = static

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.applicable_accessibilities = *
dotnet_naming_symbols.constants.required_modifiers = const

dotnet_naming_symbols.public_members.applicable_kinds = property,method,field,event
dotnet_naming_symbols.public_members.applicable_accessibilities = public,internal,protected,protected_internal,private_protected

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *

dotnet_naming_symbols.type_parameters.applicable_kinds = type_parameter

dotnet_naming_symbols.parameters.applicable_kinds = parameter
dotnet_naming_symbols.parameters.applicable_accessibilities = *

dotnet_naming_symbols.locals.applicable_kinds = local
dotnet_naming_symbols.locals.applicable_accessibilities = local

dotnet_naming_symbols.types.applicable_kinds = class,struct,enum,delegate
dotnet_naming_symbols.types.applicable_accessibilities = *

# Naming styles
dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.camel_case.capitalization = camel_case

dotnet_naming_style.interface_style.required_prefix = I
dotnet_naming_style.interface_style.capitalization = pascal_case

dotnet_naming_style.type_parameter_style.required_prefix = T
dotnet_naming_style.type_parameter_style.capitalization = pascal_case

# Rules — all enforced as ERROR per §1.1 "All rules apply ... no exceptions"
dotnet_naming_rule.private_fields_must_be_underscore_camel.symbols = private_fields
dotnet_naming_rule.private_fields_must_be_underscore_camel.style = underscore_camel_case
dotnet_naming_rule.private_fields_must_be_underscore_camel.severity = error

dotnet_naming_rule.private_static_fields_must_be_underscore_camel.symbols = private_static_fields
dotnet_naming_rule.private_static_fields_must_be_underscore_camel.style = underscore_camel_case
dotnet_naming_rule.private_static_fields_must_be_underscore_camel.severity = error

dotnet_naming_rule.constants_must_be_pascal.symbols = constants
dotnet_naming_rule.constants_must_be_pascal.style = pascal_case
dotnet_naming_rule.constants_must_be_pascal.severity = error

dotnet_naming_rule.public_members_must_be_pascal.symbols = public_members
dotnet_naming_rule.public_members_must_be_pascal.style = pascal_case
dotnet_naming_rule.public_members_must_be_pascal.severity = error

dotnet_naming_rule.interfaces_must_be_i_pascal.symbols = interfaces
dotnet_naming_rule.interfaces_must_be_i_pascal.style = interface_style
dotnet_naming_rule.interfaces_must_be_i_pascal.severity = error

dotnet_naming_rule.type_parameters_must_be_t_pascal.symbols = type_parameters
dotnet_naming_rule.type_parameters_must_be_t_pascal.style = type_parameter_style
dotnet_naming_rule.type_parameters_must_be_t_pascal.severity = error

dotnet_naming_rule.parameters_must_be_camel.symbols = parameters
dotnet_naming_rule.parameters_must_be_camel.style = camel_case
dotnet_naming_rule.parameters_must_be_camel.severity = error

dotnet_naming_rule.locals_must_be_camel.symbols = locals
dotnet_naming_rule.locals_must_be_camel.style = camel_case
dotnet_naming_rule.locals_must_be_camel.severity = error

dotnet_naming_rule.types_must_be_pascal.symbols = types
dotnet_naming_rule.types_must_be_pascal.style = pascal_case
dotnet_naming_rule.types_must_be_pascal.severity = error

# ---------------------------------------------------------------------------
# Suppress default Microsoft rules that conflict with the team standard
# ---------------------------------------------------------------------------

# CA1707 = "Identifiers should not contain underscores" — conflicts with
# _camelCase private fields and Method_Scenario_Expected test names.
dotnet_diagnostic.CA1707.severity = none

# SA1309 = "Field names should not begin with underscore" — directly contradicts
# the team standard which REQUIRES underscore prefix on private fields.
dotnet_diagnostic.SA1309.severity = none

# SA1633 = "File should have header" — the team standard does NOT require
# file headers. Disable so the linter stops flagging it.
dotnet_diagnostic.SA1633.severity = none

# SA1101 = "Prefix local calls with this." — modern C# does not use 'this.' prefix.
dotnet_diagnostic.SA1101.severity = none

# SA1200 = "Using directives must be placed inside namespace" — conflicts with the
# team standard which places usings OUTSIDE the file-scoped namespace.
dotnet_diagnostic.SA1200.severity = none

# SA1413 = "Use trailing comma in multi-line initializers" — style preference, not enforced.
dotnet_diagnostic.SA1413.severity = none

# SA1124 = "Do not use regions" — allowed in this codebase.
dotnet_diagnostic.SA1124.severity = none

# SA1649 = "File name must match first type name including generic arity" —
# would force IMessageHandler{TMessage}.cs. Common practice is plain
# IMessageHandler.cs without the curly-brace suffix.
dotnet_diagnostic.SA1649.severity = none

# CA1031 = "Do not catch general exception types" — top-level resilience loops
# (consumer poll, reconnect) MUST catch Exception to prevent one bad
# message from crashing the whole process. Suppressed at call sites
# via #pragma where the catch is intentional.
dotnet_diagnostic.CA1031.severity = none

# CA1204 = "Static elements must appear before instance elements" — pure
# cosmetics; member ordering does not affect correctness.
dotnet_diagnostic.CA1204.severity = none

# CA1204 = "Static members should appear before instance members" — purely
# cosmetic; readability is harmed by mechanical reordering.
dotnet_diagnostic.CA1204.severity = none

# CA1031 = "Do not catch general exception types" — intentionally violated
# in top-level resilience loops where catching everything is correct
# (the consumer must not crash on a single bad message).
dotnet_diagnostic.CA1031.severity = none

# IDE0008 = "Use explicit type" / IDE0007 = "Use 'var'" — handled by our own var rules below.
# (Left at default suggestion severity.)

# ---------------------------------------------------------------------------
# Compiler diagnostics — nullable warnings are errors per §3.2 / §9.2
# ---------------------------------------------------------------------------
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8618.severity = error

# ---------------------------------------------------------------------------
# Style preferences — match §3.1, §3.2, §3.3, §3.5, §3.6
# ---------------------------------------------------------------------------

# §3.1 File-scoped namespaces required
csharp_style_namespace_declarations = file_scoped:error

# Using directives outside the namespace, System first
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:error

# §3.6 var preferences
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# §3.5 Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_constructors= false:suggestion
csharp_style_expression_bodied_operators = true:suggestion

# §3.2 Pattern matching / null checks
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_not_pattern = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

###############################
# JSON / YAML
###############################
[*.{json,yml,yaml}]
indent_size = 2

###############################
# XML / config
###############################
[*.{xml,csproj,props,targets,config}]
indent_size = 2
